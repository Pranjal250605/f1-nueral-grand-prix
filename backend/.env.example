# GitHub API token — avoids the 60 req/hr unauthenticated rate limit
# Get one at https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# Anthropic API key — enables live Claude commentary in PitWall
# Without this the app falls back to static templated commentary
ANTHROPIC_API_KEY=

# CORS — comma-separated list of allowed origins in production
# Leave as * for local development; set to your frontend URL in production
# Example: CORS_ORIGINS=https://your-app.com,https://www.your-app.com
CORS_ORIGINS=*

# VAE checkpoint path override (optional)
# Default: backend/checkpoints/circuit_vae.pt
MODEL_PATH=
